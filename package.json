{
  "name": "harita-studio",
  "version": "0.1.0",
  "description": "HaritaDocs launcher for consultants and project teams.",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vishalgojha/harita.git"
  },
  "bugs": {
    "url": "https://github.com/vishalgojha/harita/issues"
  },
  "homepage": "https://github.com/vishalgojha/harita#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.17"
  },
  "keywords": [
    "harita",
    "haritadocs",
    "igbc",
    "consulting",
    "nextjs",
    "cli"
  ],
  "bin": {
    "harita": "./bin/harita.mjs"
  },
  "files": [
    "bin",
    "app",
    "components",
    "data",
    "lib",
    "public",
    "scripts",
    "supabase/migrations",
    "tests",
    "README.md",
    "LICENSE",
    ".env.example",
    ".eslintrc.json",
    "components.json",
    "middleware.ts",
    "next.config.mjs",
    "package.json",
    "playwright.config.ts",
    "postcss.config.mjs",
    "tailwind.config.ts",
    "tsconfig.json"
  ],
  "scripts": {
    "dev": "next dev",
    "dev:guided": "bun run scripts/dev-guided.ts",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "prepublishOnly": "npm run lint",
    "publish:public": "npm publish --access public",
    "seed": "node scripts/seed.mjs",
    "onboard": "node bin/harita.mjs",
    "smoke": "playwright test",
    "smoke:headed": "playwright test --headed"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jszip": "^3.10.1",
    "lucide-react": "^1.8.0",
    "next": "^14.2.35",
    "pdf-lib": "^1.17.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.5.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "typescript": "^5"
  }
}
